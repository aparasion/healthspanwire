---
layout: null
permalink: /ai-index.json
---
{
  "version": "1.0",
  "generated_at": {{ site.time | date_to_xmlschema | jsonify }},
  "site": {
    "name": {{ site.title | jsonify }},
    "url": {{ site.url | jsonify }},
    "description": {{ site.description | jsonify }},
    "llms": {{ '/llms.txt' | absolute_url | jsonify }},
    "llms_full": {{ '/llms-full.txt' | absolute_url | jsonify }},
    "ai_policy": {{ '/ai-policy/' | absolute_url | jsonify }},
    "sitemap": {{ '/sitemap.xml' | absolute_url | jsonify }}
  },
  "sections": [
    {"name": "home", "url": {{ '/' | absolute_url | jsonify }}},
    {"name": "signals", "url": {{ '/signals/' | absolute_url | jsonify }}},
    {"name": "monthly_reports", "url": {{ '/monthly-reports/' | absolute_url | jsonify }}},
    {"name": "articles", "url": {{ '/articles/' | absolute_url | jsonify }}},
    {"name": "newsletter", "url": {{ '/newsletter/' | absolute_url | jsonify }}}
  ],
  "posts": [
    {% for post in site.posts %}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | absolute_url | jsonify }},
      "date": {{ post.date | date_to_xmlschema | jsonify }},
      "author": {{ post.author | default: site.author | jsonify }},
      "description": {{ post.description | default: post.excerpt | strip_html | normalize_whitespace | truncate: 220 | jsonify }},
      "categories": {{ post.categories | jsonify }},
      "tags": {{ post.tags | jsonify }},
      "signal_id": {{ post.signal_id | default: nil | jsonify }},
      "source_url": {{ post.source_url | default: nil | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
